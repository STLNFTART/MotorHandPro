# Hedera Testnet Configuration
# Copy this file to .env and fill in your actual credentials

# Hedera Network Settings
HEDERA_NETWORK=testnet  # Options: testnet, mainnet, previewnet

# Hedera Account Credentials
# Get these from your Hedera portal: https://portal.hedera.com
HEDERA_OPERATOR_ID=0.0.YOUR_ACCOUNT_ID
HEDERA_OPERATOR_KEY=0xYOUR_PRIVATE_KEY_HERE

# Hedera EVM Integration
# Your EVM-compatible address for smart contract interactions
HEDERA_EVM_ADDRESS=0xYOUR_EVM_ADDRESS_HERE
HEDERA_CONTRACT_ID=0xYOUR_CONTRACT_ADDRESS_HERE

# Hedera Native Token Configuration
# RPO Token ID on Hedera (Native HTS Token)
HEDERA_RPO_TOKEN_ID=0.0.10164696

# Token Burn Configuration
TOKEN_RATE=1.0  # 1 token = 1 second of actuation
MIN_TOKENS_REQUIRED=0.1

# Hardhat / Ethereum Configuration
# For deploying smart contracts via Hardhat
PRIVATE_KEY=your_private_key_here
HEDERA_TESTNET_RPC=https://testnet.hashio.io/api
HEDERA_MAINNET_RPC=https://mainnet.hashio.io/api

# RPO Token Allocation Addresses (Optional - defaults to deployer if not set)
FOUNDER=0x536f51e53111755f9d1327d41fe6b21a9b2b2ba1
TREASURY=0x27aa333e759b64fd4bb4eeedac8eaaaf107580ed
LEGAL=0x27aa333e759b64fd4bb4eeedac8eaaaf107580ed
COMMUNITY=0x27aa333e759b64fd4bb4eeedac8eaaaf107580ed
DEVELOPMENT=

# ============================================================================
# GCP Backend Configuration (Optional)
# ============================================================================

# Backend type: 'local' or 'gcp'
# local: Store telemetry/experiments in-memory (development)
# gcp: Use Google Cloud Platform backends (production)
MHP_BACKEND=local

# GCP Project ID (required if MHP_BACKEND=gcp)
GCP_PROJECT=your-project-id

# BigQuery dataset name
BQ_DATASET=motorhandpro

# GCS bucket name (for artifacts)
GCS_BUCKET=motorhandpro-artifacts

# GCP region (optional)
GCP_REGION=us-central1

# Authentication: Use Application Default Credentials (ADC)
# For local development: gcloud auth application-default login
# For production: Use Workload Identity or VM service account
# DO NOT SET: GOOGLE_APPLICATION_CREDENTIALS (no keys in repo!)

# ============================================================================
# REST API Configuration
# ============================================================================

# API server host and port
API_HOST=0.0.0.0
API_PORT=8000

# Log level
LOG_LEVEL=INFO
